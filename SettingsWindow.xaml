<Window x:Class="SidebarApp.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource StrSettingsTitle}" 
        Height="390" Width="420"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgDarkBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        ResizeMode="NoResize"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="1">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Position & Autostart -->
            <RowDefinition Height="Auto"/>
            <!-- Custom Size & Opacity -->
            <RowDefinition Height="Auto"/>
            <!-- Theme & Language -->
            <RowDefinition Height="Auto"/>
            <!-- Display Mode -->
            <RowDefinition Height="Auto"/>
            <!-- Action Buttons -->
            <RowDefinition Height="Auto"/>
            <!-- Author Info -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="{DynamicResource StrSettingsTitle}" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" Foreground="{DynamicResource AccentBrush}"/>

        <!-- AutoStart & Position Section -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="AutoStartCheckBox" Grid.Column="0" Content="{DynamicResource StrSettingsAutoStart}" Foreground="{DynamicResource TextPrimaryBrush}" Cursor="Hand" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="{DynamicResource StrSettingsPosition}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <ComboBox x:Name="PositionComboBox" Width="100" Margin="10,0,0,0" SelectionChanged="PositionComboBox_SelectionChanged"/>
            </StackPanel>
        </Grid>

        <!-- Appearance Section (Size and Opacity) -->
        <Grid Grid.Row="2" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Width Slider -->
            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <TextBlock Text="{DynamicResource StrSettingsWidth}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,3"/>
                <DockPanel>
                    <TextBlock x:Name="TxtWidthValue" Text="280" Foreground="{DynamicResource AccentBrush}" FontSize="11" Width="30" DockPanel.Dock="Right" TextAlignment="Right" VerticalAlignment="Center"/>
                    <Slider x:Name="WidthSlider" Minimum="200" Maximum="400" Value="280" SmallChange="10" LargeChange="50" IsSnapToTickEnabled="True" TickFrequency="10" ValueChanged="WidthSlider_ValueChanged" VerticalAlignment="Center"/>
                </DockPanel>
            </StackPanel>

            <!-- Opacity Slider -->
            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="{DynamicResource StrSettingsOpacity}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,3"/>
                <DockPanel>
                    <TextBlock x:Name="TxtOpacityValue" Text="80%" Foreground="{DynamicResource AccentBrush}" FontSize="11" Width="35" DockPanel.Dock="Right" TextAlignment="Right" VerticalAlignment="Center"/>
                    <Slider x:Name="OpacitySlider" Minimum="0.3" Maximum="1.0" Value="0.8" SmallChange="0.05" LargeChange="0.1" ValueChanged="OpacitySlider_ValueChanged" VerticalAlignment="Center"/>
                </DockPanel>
            </StackPanel>
        </Grid>

        <!-- Theme & Language Section -->
        <Grid Grid.Row="3" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Margin="0,0,10,0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource StrSettingsTheme}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <ComboBox x:Name="ThemeComboBox" Width="100" Margin="10,0,0,0" SelectionChanged="ThemeComboBox_SelectionChanged"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="10,0,0,0" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource StrSettingsLang}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <ComboBox x:Name="LanguageComboBox" Width="100" Margin="10,0,0,0" SelectionChanged="LanguageComboBox_SelectionChanged"/>
            </StackPanel>
        </Grid>

        <!-- Display Mode Section -->
        <Grid Grid.Row="4" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{DynamicResource StrSettingsPinMode}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}"/>
                <ComboBox x:Name="PinModeComboBox" Width="110" Margin="10,0,0,0" SelectionChanged="PinModeComboBox_SelectionChanged"/>
            </StackPanel>
        </Grid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource StrSettingsBtnSave}" Click="Save_Click" Width="80" Style="{StaticResource ModernButtonStyle}" Background="{DynamicResource AccentBrush}" Foreground="{DynamicResource TextSelectedBrush}" FontWeight="Bold" Margin="0,0,10,0"/>
            <Button Content="{DynamicResource StrSettingsBtnCancel}" Click="Cancel_Click" Width="80" Style="{StaticResource ModernButtonStyle}" Background="{DynamicResource BorderBrush}"/>
        </StackPanel>

        <!-- Author Info & Website -->
        <DockPanel Grid.Row="6" Margin="0,15,0,0" LastChildFill="False">
            <TextBlock VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                <Run Text="{DynamicResource StrAuthorWeChat}"/>
            </TextBlock>
            <TextBlock DockPanel.Dock="Right" VerticalAlignment="Center" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}">
                <Run Text="{DynamicResource StrAuthorWebsite}"/>
                <Hyperlink NavigateUri="http://www.lscad.top" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}" Cursor="Hand">
                    <Run Text="www.lscad.top"/>
                </Hyperlink>
            </TextBlock>
        </DockPanel>
    </Grid>
</Window>
