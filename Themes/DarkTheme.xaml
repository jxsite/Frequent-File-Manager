<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Color Palette - Dark -->
    <SolidColorBrush x:Key="BgDarkBrush" Color="#CC1E1E2E"/>
    <SolidColorBrush x:Key="BgCardBrush" Color="#1F1F2E"/>
    <SolidColorBrush x:Key="BgCardHoverBrush" Color="#2A2A3D"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#CBA6F7"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#CDD6F4"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A6ADC8"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#313244"/>
    <SolidColorBrush x:Key="AccentAlphaBrush" Color="#30CBA6F7"/>
    
    <!-- Status colors -->
    <SolidColorBrush x:Key="TextMutedBrush" Color="#585B70"/>
    <SolidColorBrush x:Key="YellowBrush" Color="#F9E2AF"/>
    <SolidColorBrush x:Key="GreenBrush" Color="#A6E3A1"/>
    <SolidColorBrush x:Key="RedBrush" Color="#F38BA8"/>
    <SolidColorBrush x:Key="TextSelectedBrush" Color="#11111B"/>
</ResourceDictionary>
